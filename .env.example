# LLM Keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Security
INTERNAL_API_KEY=generate_a_uuid4_here

# Storage (leave defaults for local, override for production)
CHROMA_PERSIST_PATH=data/chroma_db
SQLITE_DB_PATH=backend/data/ck_workspace.db

# Database Engine (sqlite for local dev; postgres for production)
DATABASE_TYPE=sqlite
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# CORS (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:3000

# Model Config
GEMINI_MODEL=gemini-2.5-flash
# Comma-separated fallbacks when primary model is rate-limited
GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-1.5-flash
OPENROUTER_MODEL_NAME=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_FALLBACK_MODELS=google/gemma-2-9b-it:free,microsoft/phi-3-mini-128k-instruct:free,qwen/qwen-2.5-7b-instruct:free

# RAG Tuning
MIN_SIMILARITY_THRESHOLD=0.50
TOP_K_RETRIEVAL=5
